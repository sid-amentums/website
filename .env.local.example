# Public — safe to expose to the browser (Next.js inlines NEXT_PUBLIC_* at build time)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only — NEVER prefix with NEXT_PUBLIC_, never commit, never log, never return in an API response.
SUPABASE_SERVICE_ROLE_KEY=

# Public-safe convenience copy of the Razorpay key_id for local dev (also stored in app_settings table).
# The Razorpay key_secret is intentionally NOT an env var — it lives only in Supabase Vault.
RAZORPAY_KEY_ID=
